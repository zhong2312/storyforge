{
  "name": "storyforge",
  "private": true,
  "version": "3.7.3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "check:required-tables": "node scripts/check-required-tables.mjs",
    "gen:ai-manual": "node scripts/generate-ai-manual.mjs",
    "check:ai-manual": "node scripts/generate-ai-manual.mjs --check",
    "check:architecture": "node scripts/check-architecture.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "ci": "npm run check:required-tables && npm run check:ai-manual && npm run check:architecture && npx tsc --noEmit && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-text-style": "3.22.3",
    "@tiptap/pm": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@types/d3-hierarchy": "^3.1.7",
    "d3-hierarchy": "^3.1.2",
    "delaunator": "^5.1.0",
    "dexie": "^4.0.11",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.11",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-force-graph-2d": "^1.29.1",
    "react-router-dom": "^7.1.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.10.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^2.1.9"
  }
}
